{
  "manifest_version": 3,
  "name": "Bandcamp Cart Player",
  "version": "0.3.0",
  "description": "Embeds a playlist player into your Bandcamp cart",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bandcamp Cart Player"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://bandcamp.com/*", "https://*.bandcamp.com/*"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bandcamp-cart-player@extension",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.bandcamp.com/*", "https://bandcamp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
